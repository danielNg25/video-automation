# API keys (Anthropic / DeepSeek / OpenAI / ElevenLabs / Google) are entered
# in the Settings UI and stored in the browser. Nothing in .env is required
# for normal use — this file exists only for the optional overrides below.

# Optional: override the Douyin helper API URL.
#   Bare-metal default:   http://localhost:8081
#   Docker compose sets:  http://douyin-api:80  (handled automatically)
# DOUYIN_API_BASE=http://localhost:8081

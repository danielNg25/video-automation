# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
.pytest_cache/

# Data (runtime). Entire directory ignored. The .gitkeep files already in
# the index stay tracked (git ignore rules don't apply to already-tracked
# files), so fresh clones still get the directory structure.
data/


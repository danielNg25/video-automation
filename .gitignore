.env
config/config.yaml
config/douyin_cookie.txt
config/douyin_web_config.yaml
config/*_token.json
config/*_secrets.json
config/*_client_secrets.json

# Node / React
node_modules/
ui-app/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
